# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# MongoDB Atlas connection string.
# Get from: cloud.mongodb.com → your cluster → Connect → Drivers → Node.js
# Format: mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/DBNAME?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/pawpantry?retryWrites=true&w=majority

# Database name (must match the one in MONGODB_URI if you set one there).
MONGODB_DB=pawpantry

# Secret used to sign session JWTs. Must be at least 32 chars.
# Generate one with: openssl rand -base64 32
# Or in Node: require('crypto').randomBytes(32).toString('base64')
SESSION_SECRET=replace-me-with-32-plus-random-chars

# Optional: how long sessions last (defaults to 30 days).
SESSION_TTL_DAYS=30
